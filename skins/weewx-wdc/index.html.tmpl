<!--prettier-ignore-->
#errorCatcher Echo
#encoding UTF-8
#attr $context = 'day'
#attr $daily_archive = False
#attr $use_parameter_month = False
#attr $use_parameter_year = False

<!DOCTYPE html>
<html lang="$lang">
  <head>
    #include "includes/html-head.inc"
    <title>$station.location - Today's Conditions</title>
    #if 'refresh_interval' in $Extras
    <meta http-equiv="refresh" content="$Extras.refresh_interval" />
    #end if
  </head>

  <body class="theme-$DisplayOptions.get('layout', 'alternative')">
    #include "includes/ui-shell.inc"
    
    <style>
    #notification-container-mqtt{
    zoom:80%;
    width:40%;
    float:right;display: none!important;
    }
    #header-area{
    width:60%;
    float:left;
    }
    header.page-header {
    margin-bottom: var(--cds-spacing-07, 1rem)!important;
    }
    @media (max-device-width: 700px) { 
    #notification-container-mqtt {
    clear:both;
    float:left;
    width:100%;
    display: none!important;
    }
    #header-area{
    clear:both;
    width:100%;
    float:left;
    }
    }
    </style>

    <main class="main bx--content">
      <section>
        <div class="bx--grid bx--grid--full-width">
          <div class="bx--row">
            <header class="bx--col page-header">
            <div id="header-area">
              <h1><a href="">Today's Conditions</a></h1> 
              <h2>$current.dateTime.format("%d-%b-%Y")</h2> 


<style>
        /* =======================================================================
           1. COPY THIS CSS TO YOUR STYLESHEET
           ======================================================================= */
        .wf-indicator-container {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            font-size: 0.9em;
            font-weight: 500;
            margin-left: 10px;
            padding: 4px 10px;
            background: #f8f9fa;
            border-radius: 12px;
            border: 1px solid #ddd;
            color: #333;
        }

        /* Dark mode support */
        html.dark .wf-indicator-container {
            background: #374151;
            border-color: #4b5563;
            color: #f3f4f6;
        }

        .wf-status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }
        .wf-status-dot.live {
            background-color: #10b981; /* Emerald green */
            box-shadow: 0 0 0 rgba(16, 185, 129, 0.7);
            animation: wf-pulse-green 2s infinite;
        }
        .wf-status-dot.delayed {
            background-color: #ef4444; /* Red */
        }
        @keyframes wf-pulse-green {
            0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.7); }
            70% { box-shadow: 0 0 0 5px rgba(16, 185, 129, 0); }
            100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }
    </style>

    <!-- =======================================================================
         2. COPY THIS HTML EXACTLY WHERE YOU WANT IT (e.g., next to the date)
         ======================================================================= -->
    <div class="wf-indicator-container" id="wf-indicator" style="display: none;">
        <div class="wf-status-dot" id="wf-dot"></div>
        <span id="wf-text">Checking status...</span>
    </div>
    <!-- ======================================================================= -->

    <script>
        /* #raw */
        /* =======================================================================
           3. COPY THIS JAVASCRIPT TO YOUR PAGE
           ======================================================================= */
        (async function() {
            const apiUrl = 'https://swd.weatherflow.com/swd/rest/observations/device/314522?api_key=8535e71d-2290-4965-ad3f-ab05b9294fdf';
            
            const indicatorContainer = document.getElementById('wf-indicator');
            const indicatorText = document.getElementById('wf-text');
            const indicatorDot = document.getElementById('wf-dot');

            function updateUI(isLive, text) {
                indicatorContainer.style.display = 'inline-flex'; // Unhide once script runs
                indicatorText.textContent = text;
                indicatorDot.className = 'wf-status-dot ' + (isLive ? 'live' : 'delayed');
            }

            function getTimeAgoString(obsTimeMs) {
                const seconds = Math.floor((Date.now() - obsTimeMs) / 1000);
                const minutes = Math.floor(seconds / 60);
                const hours = Math.floor(minutes / 60);
                const days = Math.floor(hours / 24);

                if (days > 0) return `${days} day${days > 1 ? 's' : ''} ago`;
                if (hours > 0) return `${hours} hour${hours > 1 ? 's' : ''} ago`;
                return `${minutes} minute${minutes !== 1 ? 's' : ''} ago`;
            }

            async function checkWeatherFlowStatus() {
                try {
                    const response = await fetch(apiUrl);
                    if (!response.ok) throw new Error('Network response was not ok');
                    
                    const data = await response.json();
                    
                    // Validate data exists
                    if (data && data.obs && data.obs.length > 0) {
                        const latestObs = data.obs[0];
                        
                        // Handle both {timestamp: ...} and [timestamp, ...] formats
                        const timestampEpoch = latestObs.timestamp || latestObs[0]; 
                        const obsTimeMs = timestampEpoch * 1000;
                        
                        const diffMinutes = (Date.now() - obsTimeMs) / (1000 * 60);

                        if (diffMinutes <= 5) {
                            updateUI(true, 'Live');
                        } else {
                            updateUI(false, 'Last update ' + getTimeAgoString(obsTimeMs));
                        }
                    } else {
                        updateUI(false, 'No data available');
                    }
                } catch (error) {
                    console.error('Error fetching WeatherFlow data:', error);
                    updateUI(false, 'Sensor Offline');
                }
            }

            // Run immediately on page load
            checkWeatherFlowStatus();
            
            // Refresh the status silently every 60 seconds
            setInterval(checkWeatherFlowStatus, 60000);
        })();
        /* #end raw */
    </script>



            </div>
       
              
              
              <!--prettier-ignore-->
              #if $to_bool($Extras['mqtt']['mqtt_websockets_enabled'])
              #if $DisplayOptions.get('layout', 'alternative') == 'alternative'
                #set $mqtt_notfication_classes = "bx--col-sm-4 bx--col-md-8 bx--col-lg-12 bx--col-xlg-12 bx--col-max-12"
              #else
                #set $mqtt_notfication_classes = "bx--col-sm-4 bx--col-md-8 bx--col-lg-4 bx--col-xlg-4 bx--col-max-4"
              #end if
              <script
                type="module"
                src="https://1.www.s81c.com/common/carbon/web-components/version/v1.25.0/notification.min.js"
              ></script>
              <div
                class="bx--row"
                id="notification-container-mqtt"
                style="display: none"
              >
                <div class="$mqtt_notfication_classes">
                  <bx-inline-notification
                    style="
                      min-width: auto;
                      max-width: none;
                      margin-bottom: 0.5rem;
                    "
                    title="Connected to live weather station."
                    subtitle="Updates every minute."
                  >
                  </bx-inline-notification>
                </div>
              </div>
              #end if
            </header>
          </div>

          <!--prettier-ignore-->
          #if $DisplayOptions.get('layout', 'alternative') == 'alternative'
            #include 'includes/body-csc-tides.inc'
          #else
            #include 'includes/body-classic.inc'
          #end if
          
             

            
          
        </div>
        

        
      </section>
    </main>


         <!--Externals Modals-->
    #set $externals_list = []
    #if 'externals' in $Extras and $len($Extras['externals']) > 0
      #for $external in $Extras['externals']
        #if $external == 'description'
          #continue
        #end if
        #if $to_bool($Extras['externals'][$external].show_on_front)
          #silent $externals_list.append($external)
        #end if
      #end for
    #end if

    #if ('radar_html' in $Extras or $len($externals_list) > 0) and 'open_radar_and_externals_modal' in $Extras and $to_bool($Extras['open_radar_and_externals_modal'])
      #if 'radar_html' in $Extras
        <cds-modal id="modal-radar-default" size="md" fullWidth>
          <cds-modal-header>
            <cds-modal-close-button></cds-modal-close-button>
            <!-- <cds-modal-label>Label (Optional)</cds-modal-label> -->
            <cds-modal-heading>$gettext("Recent radar")</cds-modal-heading>
          </cds-modal-header>
          <cds-modal-body>
            $Extras.radar_html
          </cds-modal-body>
        </cds-modal>

        <script type="text/javascript">
          document
            .getElementById("panel-radar")
            .addEventListener("click", () => {
              document.getElementById("modal-radar-default").open = true;
            });

          if (document .querySelector("#panel-radar a")) {
            document
              .querySelector("#panel-radar a")
              .addEventListener("click", (event) => {
                event.preventDefault();
              });
          }
        </script>
        <style>
          #panel-radar {
            cursor: pointer;
          }
        </style>
      #end if

      #for $external in externals_list
        <cds-modal id="modal-$external" size="md" fullWidth>
          <cds-modal-header>
            <cds-modal-close-button></cds-modal-close-button>
            <cds-modal-label>$Extras['externals'][$external].title_long</cds-modal-label>
            <cds-modal-heading>$Extras['externals'][$external].title</cds-modal-heading>
          </cds-modal-header>
          <cds-modal-body>
            $Extras['externals'][$external].source
          </cds-modal-body>
        </cds-modal>

        <script type="text/javascript">
          document
            .getElementById("panel-$external")
            .addEventListener("click", () => {
              document.getElementById("modal-$external").open = true;
            });

          if (document .querySelector("#panel-$external a")) {
            document
              .querySelector("#panel-$external a")
              .addEventListener("click", (event) => {
                event.preventDefault();
              });
          }
        </script>
        <style>
          #panel-$external {
            cursor: pointer;
          }
        </style>
      #end for
    #end if

    #include "includes/footer.inc"

    #if $to_bool($DisplayOptions.get("outTemp_stat_tile_color", "False"))
    <script src="$get_base_path(path='dist/colored-temperature.js')" defer></script>
    #end if

    <script src="$get_base_path(path='dist/main.js')" defer></script>
    #if $to_bool($Extras['mqtt']['mqtt_websockets_enabled'])
    <!--prettier-ignore-->
    <script>
      var mqtt_host = "$Extras['mqtt']['mqtt_websockets_host']";
      var mqtt_port = "$Extras['mqtt']['mqtt_websockets_port']";
      var mqtt_topic = "$Extras['mqtt']['mqtt_websockets_topic']";
      var mqtt_ssl = "$Extras['mqtt']['mqtt_websockets_ssl']";
      var mqtt_username = "$Extras['mqtt']['mqtt_websockets_username']";
      var mqtt_password = "$Extras['mqtt']['mqtt_websockets_password']";
    </script>
    <script src="$get_base_path(path='dist/live-updates.js')" defer></script>
    #end if
  </body>
</html>
