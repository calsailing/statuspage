<!DOCTYPE html>
<html lang="$lang">
  <head>
    #include "includes/html-head.inc"
    <title>$station.location - Today's Conditions</title>
    #if 'refresh_interval' in $Extras
    <meta http-equiv="refresh" content="$Extras.refresh_interval" />
    #end if
  </head>

  <body class="theme-$DisplayOptions.get('layout', 'alternative')">
    #include "includes/ui-shell.inc"
    
    <style>
    #notification-container-mqtt{
    zoom:80%;
    width:40%;
    float:right;display: none!important;
    }
    #header-area{
    width:60%;
    float:left;
    }
    header.page-header {
    margin-bottom: var(--cds-spacing-07, 1rem)!important;
    }
    @media (max-device-width: 700px) { 
    #notification-container-mqtt {
    clear:both;
    float:left;
    width:100%;
    display: none!important;
    }
    #header-area{
    clear:both;
    width:100%;
    float:left;
    }
    }
    </style>

    <main class="main bx--content">
      <section>
        <div class="bx--grid bx--grid--full-width">
          <div class="bx--row">
            <header class="bx--col page-header">
            <div id="header-area">
              <h1><a href="" style="text-decoration: none">Today's Conditions</a></h1> 
<style>
  /* 1. Time string placed next to your Date */
  .wf-update-time {
    font-weight: normal;
    vertical-align: middle;
  }
  
  /* 2. Modern Status Pill placed right after the time */
  .wf-status-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 20px;
    font-family: system-ui, -apple-system, sans-serif; /* Clean native font for the pill */
    vertical-align: middle;
    margin-left: 8px;
  }

  /* Status Colors - Light Backgrounds, Darker Text */
  .wf-status-pill.online { background-color: #e6f4ea; color: #1e8e3e; }
  .wf-status-pill.delayed { background-color: #fef7e0; color: #b06000; }
  .wf-status-pill.offline { background-color: #fce8e6; color: #c5221f; }
  
  /* The Dots */
  .wf-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .online .wf-dot {
    background-color: #1e8e3e;
    animation: wf-pulse-green 2s infinite;
  }
  .delayed .wf-dot { background-color: #f9ab00; }
  .offline .wf-dot { background-color: #d93025; }

  /* Pulsing Animation for Live Status */
  @keyframes wf-pulse-green {
    0% { box-shadow: 0 0 0 0 rgba(30, 142, 62, 0.4); }
    70% { box-shadow: 0 0 0 4px rgba(30, 142, 62, 0); }
    100% { box-shadow: 0 0 0 0 rgba(30, 142, 62, 0); }
  }

  /* Dark Mode Support (Optional: Triggers if html tag has class="dark") */
  html.dark .wf-update-time { color: #fff; }
  html.dark .wf-status-pill.online { background-color: rgba(30, 142, 62, 0.2); color: #81c995; }
  html.dark .online .wf-dot { background-color: #81c995; }
  html.dark .wf-status-pill.delayed { background-color: rgba(249, 171, 0, 0.2); color: #fde293; }
  html.dark .delayed .wf-dot { background-color: #fde293; }
  html.dark .wf-status-pill.offline { background-color: rgba(217, 48, 37, 0.2); color: #f28b82; }
  html.dark .offline .wf-dot { background-color: #f28b82; }
</style>

<h2>
    <span style="vertical-align: middle;">$current.dateTime.format("%d-%b-%Y") </span> 
    <span class="wf-update-time" id="wf-time"></span> 
    <div class="wf-status-pill" id="wf-pill" style="display: none;"></div>
</h2> 

<script>
/* #raw */
(function() {
    const STATIC_TOKEN = '8535e71d-2290-4965-ad3f-ab05b9294fdf';
    const DEVICE_ID = '314522';
    
    const timeText = document.getElementById('wf-time');
    const pill = document.getElementById('wf-pill');

    let wsStatusSocket = null;
    let lastObsTimeMs = 0;
    let watchdogTimer = null;

    function getCompactTimeAgo(obsTimeMs) {
        const seconds = Math.floor((Date.now() - obsTimeMs) / 1000);
        const minutes = Math.floor(seconds / 60);
        const hours = Math.floor(minutes / 60);
        const days = Math.floor(hours / 24);

        if (days > 0) return `${days}d`;
        if (hours > 0) return `${hours}h`;
        return `${minutes}m`;
    }

    function updateIndicatorUI() {
        pill.style.display = 'inline-flex';

        // Connection entirely broken or not open
        if (!wsStatusSocket || wsStatusSocket.readyState !== WebSocket.OPEN) {
            pill.className = 'wf-status-pill offline';
            pill.innerHTML = '<div class="wf-dot"></div>Offline';
            return;
        }

        // Socket open, but waiting for the very first packet
        if (lastObsTimeMs === 0) {
            pill.className = 'wf-status-pill delayed';
            pill.innerHTML = '<div class="wf-dot"></div>Connecting...';
            return;
        }

        // Calculate time since the last packet arrived
        const diffMinutes = (Date.now() - lastObsTimeMs) / (1000 * 60);
        
        if (diffMinutes <= 5) {
            pill.className = 'wf-status-pill online';
            pill.innerHTML = '<div class="wf-dot"></div>Online';
        } else {
            const delayStr = getCompactTimeAgo(lastObsTimeMs);
            pill.className = 'wf-status-pill delayed';
            pill.innerHTML = `<div class="wf-dot"></div>Delayed ${delayStr}`;
        }
    }

    function startStatusWebsocket() {
        const wsUrl = `wss://ws.weatherflow.com/swd/data?token=${STATIC_TOKEN}`;
        wsStatusSocket = new WebSocket(wsUrl);

        wsStatusSocket.onopen = () => {
            // Subscribe to both rapid wind and standard observations so the indicator lights up immediately
            wsStatusSocket.send(JSON.stringify({ type: "listen_rapid_start", device_id: DEVICE_ID, id: "indicator_rapid" }));
            wsStatusSocket.send(JSON.stringify({ type: "listen_start", device_id: DEVICE_ID, id: "indicator_obs" }));
            updateIndicatorUI();
        };

        wsStatusSocket.onmessage = (event) => {
            const msg = JSON.parse(event.data);
            let packetTimeEpoch = 0;
            
            // Extract the timestamp based on the message format
            if (msg.type === 'obs_st') {
                packetTimeEpoch = msg.obs[0][0]; 
            } else if (msg.type === 'rapid_wind') {
                packetTimeEpoch = msg.ob[0];
            }

            if (packetTimeEpoch > 0) {
                lastObsTimeMs = packetTimeEpoch * 1000;
                
                // Update the time readout immediately
                const obsDate = new Date(lastObsTimeMs);
                timeText.textContent = obsDate.toLocaleTimeString('en-US', { timeZone: 'America/Los_Angeles', hour: '2-digit', minute: '2-digit', hour12: false });
                
                updateIndicatorUI();
            }
        };

        wsStatusSocket.onclose = () => {
            updateIndicatorUI();
            // Automatically attempt to reconnect after a 5 second delay
            setTimeout(startStatusWebsocket, 5000);
        };

        wsStatusSocket.onerror = () => {
            wsStatusSocket.close(); // Force the connection to close and trigger the reconnection loop
        };
    }

    // 1. Start the WebSocket immediately
    startStatusWebsocket();

    // 2. Start a continuous watchdog timer to check for delays every 10 seconds
    if (watchdogTimer) clearInterval(watchdogTimer);
    watchdogTimer = setInterval(updateIndicatorUI, 10000);

})();
/* #end raw */
</script>

    



            </div>
      
              
              
              <!--prettier-ignore-->
              #if $to_bool($Extras['mqtt']['mqtt_websockets_enabled'])
              #if $DisplayOptions.get('layout', 'alternative') == 'alternative'
                #set $mqtt_notfication_classes = "bx--col-sm-4 bx--col-md-8 bx--col-lg-12 bx--col-xlg-12 bx--col-max-12"
              #else
                #set $mqtt_notfication_classes = "bx--col-sm-4 bx--col-md-8 bx--col-lg-4 bx--col-xlg-4 bx--col-max-4"
              #end if
              <script
                type="module"
                src="https://1.www.s81c.com/common/carbon/web-components/version/v1.25.0/notification.min.js"
              ></script>
              <div
                class="bx--row"
                id="notification-container-mqtt"
                style="display: none"
              >
                <div class="$mqtt_notfication_classes">
                  <bx-inline-notification
                    style="
                      min-width: auto;
                      max-width: none;
                      margin-bottom: 0.5rem;
                    "
                    title="Connected to live weather station."
                    subtitle="Updates every minute."
                  >
                  </bx-inline-notification>
                </div>
              </div>
              #end if
            </header>
          </div>

          <!--prettier-ignore-->
          #if $DisplayOptions.get('layout', 'alternative') == 'alternative'
            #include 'includes/body-csc-tides.inc'
          #else
            #include 'includes/body-classic.inc'
          #end if
          
             

            
          
        </div>
        

        
      </section>
    </main>


         <!--Externals Modals-->
    #set $externals_list = []
    #if 'externals' in $Extras and $len($Extras['externals']) > 0
      #for $external in $Extras['externals']
        #if $external == 'description'
          #continue
        #end if
        #if $to_bool($Extras['externals'][$external].show_on_front)
          #silent $externals_list.append($external)
        #end if
      #end for
    #end if

    #if ('radar_html' in $Extras or $len($externals_list) > 0) and 'open_radar_and_externals_modal' in $Extras and $to_bool($Extras['open_radar_and_externals_modal'])
      #if 'radar_html' in $Extras
        <cds-modal id="modal-radar-default" size="md" fullWidth>
          <cds-modal-header>
            <cds-modal-close-button></cds-modal-close-button>
            <!-- <cds-modal-label>Label (Optional)</cds-modal-label> -->
            <cds-modal-heading>$gettext("Recent radar")</cds-modal-heading>
          </cds-modal-header>
          <cds-modal-body>
            $Extras.radar_html
          </cds-modal-body>
        </cds-modal>

        <script type="text/javascript">
          document
            .getElementById("panel-radar")
            .addEventListener("click", () => {
              document.getElementById("modal-radar-default").open = true;
            });

          if (document .querySelector("#panel-radar a")) {
            document
              .querySelector("#panel-radar a")
              .addEventListener("click", (event) => {
                event.preventDefault();
              });
          }
        </script>
        <style>
          #panel-radar {
            cursor: pointer;
          }
        </style>
      #end if

      #for $external in externals_list
        <cds-modal id="modal-$external" size="md" fullWidth>
          <cds-modal-header>
            <cds-modal-close-button></cds-modal-close-button>
            <cds-modal-label>$Extras['externals'][$external].title_long</cds-modal-label>
            <cds-modal-heading>$Extras['externals'][$external].title</cds-modal-heading>
          </cds-modal-header>
          <cds-modal-body>
            $Extras['externals'][$external].source
          </cds-modal-body>
        </cds-modal>

        <script type="text/javascript">
          document
            .getElementById("panel-$external")
            .addEventListener("click", () => {
              document.getElementById("modal-$external").open = true;
            });

          if (document .querySelector("#panel-$external a")) {
            document
              .querySelector("#panel-$external a")
              .addEventListener("click", (event) => {
                event.preventDefault();
              });
          }
        </script>
        <style>
          #panel-$external {
            cursor: pointer;
          }
        </style>
      #end for
    #end if

    #include "includes/footer.inc"

    #if $to_bool($DisplayOptions.get("outTemp_stat_tile_color", "False"))
    <script src="$get_base_path(path='dist/colored-temperature.js')" defer></script>
    #end if

    <script src="$get_base_path(path='dist/main.js')" defer></script>
    #if $to_bool($Extras['mqtt']['mqtt_websockets_enabled'])
    <!--prettier-ignore-->
    <script>
      var mqtt_host = "$Extras['mqtt']['mqtt_websockets_host']";
      var mqtt_port = "$Extras['mqtt']['mqtt_websockets_port']";
      var mqtt_topic = "$Extras['mqtt']['mqtt_websockets_topic']";
      var mqtt_ssl = "$Extras['mqtt']['mqtt_websockets_ssl']";
      var mqtt_username = "$Extras['mqtt']['mqtt_websockets_username']";
      var mqtt_password = "$Extras['mqtt']['mqtt_websockets_password']";
    </script>
    <script src="$get_base_path(path='dist/live-updates.js')" defer></script>
    #end if
  </body>
</html>
